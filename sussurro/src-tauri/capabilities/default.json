{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "overlay"],
  "permissions": [
    "core:default",
    "opener:default",
    "updater:default",
    "process:allow-restart",
    "dialog:allow-open",
    "dialog:allow-save",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://ollama.com/*" }]
    }
  ]
}
