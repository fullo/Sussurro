{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sussurro",
  "version": "0.1.0",
  "identifier": "com.sussurro.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Sussurro",
        "width": 700,
        "height": 860,
        "minWidth": 560,
        "minHeight": 640
      },
      {
        "label": "overlay",
        "title": "Sussurro overlay",
        "width": 210,
        "height": 52,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focusable": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
